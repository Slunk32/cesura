# Spotify — register an app at https://developer.spotify.com/dashboard
# Add http://127.0.0.1:5173/callback (and your Vercel URL + /callback) as Redirect URIs.
# Only the Client ID is needed — PKCE means no client secret in the browser.
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id-here

# Last.fm — get a key at https://www.last.fm/api/account/create
# Stays server-side; only used by /api/similar.
LASTFM_API_KEY=your-lastfm-api-key-here
